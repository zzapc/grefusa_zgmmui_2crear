<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout"
xmlns:form="sap.ui.layout.form">
	<Dialog showHeader="true" title="{i18n>TituloCampanya}">
		<customHeader>
			<Toolbar>
				<ToolbarSpacer/>
				<Text text="{i18n>TituloCampanya}"/>
				<ToolbarSpacer/>
			</Toolbar>
		</customHeader>
		<subHeader>
			<Toolbar>
				<SearchField
					id = "buscarGrupoArticulos"
					liveChange = ".onBuscarGrupoArticulos"/>
			</Toolbar>
		</subHeader>
		<content>	
			<List 
					id="listaGrupoArticulos"
				    mode = "SingleSelectMaster"
				    itemPress =".onChangeGrupoArticulos"
				    selectionChange	=".onChangeGrupoArticulos"
					items ="{grupoArticulos>/}">
				<items>
					<StandardListItem description="{grupoArticulos>Descripcion}" title="{grupoArticulos>Codigo}"/>
				</items>
			</List>
		</content>
		<buttons>
			<Button text="{i18n>BotonCerrar}" press=".onPressCerrarGrupoArticulos"/>
		</buttons>
	</Dialog>
</core:FragmentDefinition>